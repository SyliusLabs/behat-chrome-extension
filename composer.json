{
    "name": "sylius-labs/behat-chrome-extension",
    "description": "Behat extension for controlling Chrome without Selenium — fork maintained by SyliusLabs",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "chrome",
        "behat",
        "driver",
        "headless"
    ],
    "authors": [
        {
            "name": "Dorian More",
            "email": "doriancmore@gmail.com"
        }
    ],
    "homepage": "https://github.com/SyliusLabs/behat-chrome-extension",
    "require": {
        "php": ">=7.1",
        "behat/behat": "^3.0.4 || ^4.0",
        "dmore/chrome-mink-driver": "^2.4.1",
        "friends-of-behat/mink-extension": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5 || ^9.5"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "DMore\\ChromeExtension\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "phpro/grumphp-shim": true
        }
    }
}
